# Database
DATABASE_URL=postgresql+asyncpg://node@localhost:5432/pricetracker
DATABASE_URL_SYNC=postgresql://node@localhost:5432/pricetracker

# Redis
REDIS_URL=redis://localhost:6379/0

# Airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql://node@localhost:5432/airflow
AIRFLOW__CORE__EXECUTOR=SequentialExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW_HOME=/workspace/price-tracker/airflow

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Scraper
SCRAPE_DELAY_MIN=2
SCRAPE_DELAY_MAX=5
SCRAPE_MAX_PAGES=3
